# ── Model ─────────────────────────────────────────────────────────────────
# Ollama must be running locally (http://localhost:11434)
MODEL=mistral-small:22b

AT_RISK_THRESHOLD=75.0

# ── Vector DB ─────────────────────────────────────────────────────────────
# Embedding model served by Ollama
EMBED_MODEL=nomic-embed-text
# Persistent ChromaDB directory
CHROMA_PATH=./data/chroma_db

# ── MCP Server ────────────────────────────────────────────────────────────
# Path to attendance data files (CSV/Excel/Parquet)
ATTENDANCE_DATA_PATH=./data/attendance

# Identity of the MCP server process
# Role: admin | teacher | counselor | viewer
MCP_USER_ID=mcp_user
MCP_USER_ROLE=admin
# Pipe-separated class whitelist; leave empty for unrestricted (admin only)
MCP_ALLOWED_CLASSES=

# ── Web API ───────────────────────────────────────────────────────────────
# Secret key for JWT signing — change this in production
JWT_SECRET=change-me-in-production
# Default admin password (used only on first startup if api/users.json is empty)
ADMIN_PASSWORD=admin123

# ── Multi-user token registry (optional) ─────────────────────────────────
# Format: token:role:class1|class2,token2:role2:class3
# Example: abc123:teacher:10A|10B,def456:admin:,ghi789:counselor:10A|10B|11A
EXCELSIS_TOKENS=

# ── Model ─────────────────────────────────────────────────────────────────
# Ollama must be running locally (http://localhost:11434)
MODEL=mistral-small:22b

AT_RISK_THRESHOLD=75.0

# ── SQL Server ────────────────────────────────────────────────────────────
# Single SQL Server instance; multiple databases comma-separated
SQL_SERVER=myserver.corp
SQL_DATABASES=attendance_db,enrollment_db,hr_db
SQL_PRIMARY_DB=attendance_db
SQL_DRIVER={ODBC Driver 18 for SQL Server}

# Authentication — choose one method (auth wired in a later phase)
# sql: SQL Server login (username + password below)
# windows: Windows / Active Directory integrated auth (no password needed)
# azure_ad: Azure Active Directory / Entra ID (configured separately)
SQL_AUTH_METHOD=sql
SQL_USERNAME=placeholder_change_me
SQL_PASSWORD=placeholder_change_me

# ── MCP Server ────────────────────────────────────────────────────────────
# Identity of the MCP server process
# Role: admin | teacher | counselor | viewer
MCP_USER_ID=mcp_user
MCP_USER_ROLE=admin
# Pipe-separated class whitelist; leave empty for unrestricted (admin only)
MCP_ALLOWED_CLASSES=

# ── Web API ───────────────────────────────────────────────────────────────
# Secret key for JWT signing — change this in production
JWT_SECRET=change-me-in-production
# Default admin password (used only on first startup if api/users.json is empty)
ADMIN_PASSWORD=admin123

# ── Multi-user token registry (optional) ─────────────────────────────────
# Format: token:role:class1|class2,token2:role2:class3
# Example: abc123:teacher:10A|10B,def456:admin:,ghi789:counselor:10A|10B|11A
EXCELSIS_TOKENS=

# ── Model ─────────────────────────────────────────────────────────────────────
# Cloud Ollama (api.ollama.com) or local (http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
MODEL=qwen2.5:14b

AT_RISK_THRESHOLD=75.0

# ── Schema / Domain Config ────────────────────────────────────────────────────
# Configure these to point the agent at any tabular SQL schema
PRIMARY_TABLE=your_table_name
METRIC_COLUMN=status
POSITIVE_VALUE=active
DATE_COLUMN=date
ENTITY_COLUMN=entity_id
ENTITY_NAME_COLUMN=entity_name
GROUP_COLUMNS=

# ── SQL Server ────────────────────────────────────────────────────────────────
# Single SQL Server instance; multiple databases comma-separated
SQL_SERVER=myserver.corp
SQL_DATABASES=primary_db
SQL_PRIMARY_DB=primary_db
SQL_DRIVER={ODBC Driver 18 for SQL Server}
# Auth method: sql (username/password) or windows (current Windows session)
SQL_AUTH_METHOD=sql
SQL_USERNAME=placeholder_change_me
SQL_PASSWORD=placeholder_change_me
SQL_POOL_SIZE=5
SQL_QUERY_TIMEOUT=30
SQL_CACHE_TTL=300
SQL_CACHE_MAX_SIZE=512

# ── RAG / Vector Store ────────────────────────────────────────────────────────
# Path to the persistent ChromaDB directory (relative to project root)
CHROMA_PATH=.chroma
# HuggingFace embedding model — downloaded automatically on first run
EMBED_MODEL=BAAI/bge-small-en-v1.5
# Directory scanned for policy docs (.pdf and .md)
DOCS_PATH=docs
RAG_CACHE_TTL=3600

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_USER_ID=mcp_user

# ── Redis (optional — enables shared rate limiting across multiple workers) ────
# Leave empty to use per-process in-memory counters (fine for single worker)
# Format: redis://[:password]@host[:port][/db]
REDIS_URI=

# ── Web API ───────────────────────────────────────────────────────────────────
# REQUIRED: Set a strong random value before starting (startup will fail if left as default)
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
# Default admin password set on first startup (must be >= 12 chars)
ADMIN_PASSWORD=change-me-admin-password
# Path to the SQLite file used for persistent per-user conversation history
CHAT_DB=./chat.db
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Prompt Validation ─────────────────────────────────────────────────────────
# Maximum length (chars) of a single chat message
MAX_MESSAGE_LEN=2000
# Maximum estimated tokens (message + conversation history) before rejection
MAX_PROMPT_TOKENS=2048

# ── MLflow Observability (optional) ──────────────────────────────────────────
# Leave empty to disable all tracking (zero overhead, mlflow not imported)
# Local:  MLFLOW_TRACKING_URI=http://localhost:5000
# Remote: MLFLOW_TRACKING_URI=https://your-mlflow-server
MLFLOW_TRACKING_URI=

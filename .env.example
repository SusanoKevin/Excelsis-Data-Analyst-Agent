# ── Model ─────────────────────────────────────────────────────────────────
# Ollama must be running locally (http://localhost:11434)
MODEL=phi4:14b

AT_RISK_THRESHOLD=75.0

# ── Schema / Domain Config ────────────────────────────────────────────────
# Configure these to point the agent at any tabular SQL schema
PRIMARY_TABLE=attendance
METRIC_COLUMN=status
POSITIVE_VALUE=present
DATE_COLUMN=date
ENTITY_COLUMN=student_id
ENTITY_NAME_COLUMN=student_name
GROUP_COLUMNS=class,grade

# ── SQL Server ────────────────────────────────────────────────────────────
# Single SQL Server instance; multiple databases comma-separated
SQL_SERVER=myserver.corp
SQL_DATABASES=attendance_db,enrollment_db,hr_db
SQL_PRIMARY_DB=attendance_db
SQL_DRIVER={ODBC Driver 18 for SQL Server}
SQL_USERNAME=placeholder_change_me
SQL_PASSWORD=placeholder_change_me

# ── RAG / Vector Store ────────────────────────────────────────────────────
# Path to the persistent ChromaDB directory (relative to project root)
CHROMA_PATH=.chroma
# Ollama embedding model — must be pulled first: ollama pull nomic-embed-text
EMBED_MODEL=nomic-embed-text
# Directory scanned for policy docs (.pdf and .md)
DOCS_PATH=docs

# ── MCP Server ────────────────────────────────────────────────────────────
MCP_USER_ID=mcp_user

# ── Web API ───────────────────────────────────────────────────────────────
# Secret key for JWT signing — change this in production
JWT_SECRET=change-me-in-production
# Default admin password (used only on first startup if api/users.json is empty)
ADMIN_PASSWORD=admin123

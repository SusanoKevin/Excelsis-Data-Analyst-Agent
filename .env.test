# ── Docker test database ──────────────────────────────────────────────────────
# Run:  docker compose -f docker/docker-compose.yml up -d
# Seed: python scripts/seed_test_db.py --scale large
# Use:  cp .env.test .env

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL=qwen2.5:14b
AT_RISK_THRESHOLD=75.0

# ── SQL Server (Docker) ───────────────────────────────────────────────────────
SQL_SERVER=localhost,1433
SQL_DATABASES=primary_db,secondary_db
SQL_PRIMARY_DB=primary_db
SQL_USERNAME=sa
SQL_PASSWORD=ExcelsisTest_2024!
SQL_DRIVER={ODBC Driver 18 for SQL Server}
SQL_POOL_SIZE=5
SQL_QUERY_TIMEOUT=30

# ── Schema / Domain Config ────────────────────────────────────────────────────
PRIMARY_TABLE=records
METRIC_COLUMN=status
POSITIVE_VALUE=active
DATE_COLUMN=date
ENTITY_COLUMN=entity_id
ENTITY_NAME_COLUMN=entity_name
GROUP_COLUMNS=segment,category

# ── RAG / Vector Store ────────────────────────────────────────────────────────
CHROMA_PATH=.chroma
EMBED_MODEL=nomic-embed-text
DOCS_PATH=docs

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_USER_ID=mcp_user

# ── Web API ───────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-not-for-production
ADMIN_PASSWORD=admin123

# ── Prompt Validation ─────────────────────────────────────────────────────────
MAX_MESSAGE_LEN=2000
MAX_PROMPT_TOKENS=2048
